{
	"name": "task-management-backend",
	"version": "1.0.0",
	"description": "REST API backend for task management application",
	"main": "dist/server.js",
	"scripts": {
		"dev": "nodemon src/server.ts",
		"build": "tsc",
		"start": "node dist/server.js",
		"format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.md\"",
		"format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \"*.md\"",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"keywords": [
		"express",
		"typescript",
		"rest-api",
		"task-management"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@faker-js/faker": "^10.0.0",
		"compression": "^1.7.4",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.21.1",
		"express-rate-limit": "^7.4.1",
		"helmet": "^8.0.0",
		"morgan": "^1.10.0",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@types/compression": "^1.7.5",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/morgan": "^1.9.9",
		"@types/node": "^22.10.2",
		"@types/uuid": "^10.0.0",
		"nodemon": "^3.1.9",
		"prettier": "^3.6.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.2"
	}
}
