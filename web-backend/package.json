{
	"name": "task-management-backend",
	"version": "1.0.0",
	"description": "REST API backend for task management application",
	"main": "dist/server.js",
	"scripts": {
		"dev": "nodemon src/server.ts",
		"build": "tsc",
		"start": "node dist/server.js",
		"format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.md\"",
		"format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \"*.md\"",
		"test": "NODE_ENV=test jest",
		"test:watch": "NODE_ENV=test jest --watch",
		"test:coverage": "NODE_ENV=test jest --coverage",
		"db:seed": "npx ts-node -r tsconfig-paths/register src/db/seed.ts"
	},
	"keywords": [
		"express",
		"typescript",
		"rest-api",
		"task-management"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@faker-js/faker": "^10.0.0",
		"@neondatabase/serverless": "^1.0.2",
		"compression": "^1.7.4",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.45.0",
		"express": "^4.21.1",
		"express-rate-limit": "^7.4.1",
		"google-auth-library": "^10.5.0",
		"helmet": "^8.0.0",
		"jsonwebtoken": "^9.0.3",
		"morgan": "^1.10.0",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@types/compression": "^1.7.5",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.9",
		"@types/node": "^22.10.2",
		"@types/supertest": "^6.0.3",
		"@types/uuid": "^10.0.0",
		"drizzle-kit": "^0.31.8",
		"jest": "^30.2.0",
		"nodemon": "^3.1.9",
		"prettier": "^3.6.2",
		"supertest": "^7.1.4",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.2"
	}
}
